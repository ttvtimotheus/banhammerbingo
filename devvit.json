{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "banhammerbingo",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create Banhammer Bingo post",
        "description": "Start a daily community chaos sim",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "forms": {
    "exampleForm": "/internal/form/example-submit"
  },
  "scheduler": {
    "tasks": {
      "daily-resolution": {
        "endpoint": "/internal/scheduler/daily-resolution"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  }
}
